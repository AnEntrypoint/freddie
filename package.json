{
  "name": "freddie",
  "version": "0.0.205",
  "type": "module",
  "description": "Open JS agent harness built on pi-mono, floosie, xstate, and anentrypoint-design",
  "bin": {
    "freddie": "./bin/freddie.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./browser": {
      "browser": "./dist/browser/freddie.js",
      "default": "./src/browser/index.js"
    },
    "./plugins/*": "./plugins/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "start": "node bin/freddie.js",
    "test": "node test.js",
    "lint": "node scripts/lint.mjs",
    "build:browser": "vite build --config vite.browser.config.js",
    "link-local-design": "node scripts/link-local-design.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-tui": "^0.80.10",
    "@libsql/client": "^0.17.4",
    "acptoapi": "^1.0.167",
    "anentrypoint-design": "^0.0.340",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "flatspace": "^1.0.18",
    "floosie": "^0.7.6",
    "gm-plugkit": "^2.0.1925",
    "gm-skill": "^2.0.1925",
    "js-yaml": "^5.2.1",
    "msgpackr": "^2.0.4",
    "plugsdk": "^1.0.20",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.12",
    "ws": "^8.21.1",
    "xstate": "^5.32.5"
  },
  "optionalDependencies": {
    "@libsql/darwin-arm64": "0.3.19",
    "@libsql/darwin-x64": "0.3.19",
    "@libsql/linux-arm64-gnu": "0.3.19",
    "@libsql/linux-arm64-musl": "0.3.19",
    "@libsql/linux-x64-gnu": "0.3.19",
    "@libsql/linux-x64-musl": "0.3.19",
    "@libsql/win32-x64-msvc": "^0.5.29"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "overrides": {
    "fast-xml-builder": "^1.1.7"
  },
  "files": [
    "bin/",
    "src/",
    "plugins/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnEntrypoint/freddie.git"
  },
  "bugs": {
    "url": "https://github.com/AnEntrypoint/freddie/issues"
  },
  "homepage": "https://github.com/AnEntrypoint/freddie#readme",
  "license": "MIT",
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "coding-agent",
    "freddie",
    "pi-mono",
    "xstate"
  ],
  "devDependencies": {
    "esbuild": "^0.28.0",
    "vite": "^8.1.5",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}
